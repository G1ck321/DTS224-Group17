{
  "version": 2,
  "builds": [
    {
      "src": "Backend/src/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["Backend/src/**"]
      }
    },
    {
      "src": "Frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Backend/src/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "Frontend/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}